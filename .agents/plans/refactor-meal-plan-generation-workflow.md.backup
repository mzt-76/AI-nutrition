### CREATE `tests/test_meal_distribution.py`

**IMPLEMENT**: Unit tests for macro distribution calculator

**PATTERN**: Mirror `tests/test_meal_planning.py` (lines 1-100) - simple pytest functions, assert statements

**IMPORTS**:
```python
from nutrition.meal_distribution import calculate_meal_macros_distribution
```

**TEST CASES**:
```python
def test_calculate_meal_macros_distribution_3_meals_2_snacks():
    """Test distribution for 3 main meals + 2 snacks structure."""
    result = calculate_meal_macros_distribution(3300, 174, 413, 92, "3_meals_2_snacks")

    assert len(result["meals"]) == 5
    assert result["daily_totals"]["calories"] == 3300
    assert result["daily_totals"]["protein_g"] == 174

    # Main meals should have ~25% of calories each (75% / 3)
    main_meals = [m for m in result["meals"] if "Petit-déjeuner" in m["meal_type"] or "Déjeuner" in m["meal_type"] or "Dîner" in m["meal_type"]]
    assert len(main_meals) == 3
    assert all(800 <= m["target_calories"] <= 850 for m in main_meals)

    # Snacks should have ~12.5% of calories each (25% / 2)
    snacks = [m for m in result["meals"] if "Collation" in m["meal_type"]]
    assert len(snacks) == 2
    assert all(400 <= m["target_calories"] <= 425 for m in snacks)

def test_calculate_meal_macros_distribution_4_meals():
    """Test equal distribution for 4 equal meals structure."""
    result = calculate_meal_macros_distribution(2800, 160, 350, 80, "4_meals")

    assert len(result["meals"]) == 4
    # All meals should have ~25% of calories
    assert all(680 <= m["target_calories"] <= 720 for m in result["meals"])

def test_calculate_meal_macros_distribution_3_consequent_meals():
    """Test distribution for 3 meals with no snacks."""
    result = calculate_meal_macros_distribution(2400, 150, 300, 70, "3_consequent_meals")

    assert len(result["meals"]) == 3
    # Equal split: 2400 / 3 = 800 kcal per meal
    assert all(790 <= m["target_calories"] <= 810 for m in result["meals"])

def test_calculate_meal_macros_distribution_totals_sum_correctly():
    """Test that meal macros sum to daily totals (with rounding tolerance)."""
    result = calculate_meal_macros_distribution(3000, 180, 375, 85, "3_meals_2_snacks")

    # Sum all meal macros
    total_cals = sum(m["target_calories"] for m in result["meals"])
    total_protein = sum(m["target_protein_g"] for m in result["meals"])
    total_carbs = sum(m["target_carbs_g"] for m in result["meals"])
    total_fat = sum(m["target_fat_g"] for m in result["meals"])

    # Allow ±10 kcal tolerance for rounding
    assert abs(total_cals - 3000) <= 10
    assert abs(total_protein - 180) <= 5
    assert abs(total_carbs - 375) <= 10
    assert abs(total_fat - 85) <= 3

def test_calculate_meal_macros_distribution_includes_meal_times():
    """Test that each meal has time information extracted from structure."""
    result = calculate_meal_macros_distribution(3000, 180, 375, 85, "3_meals_1_preworkout")

    for meal in result["meals"]:
        assert "meal_type" in meal
        assert "time" in meal
        assert meal["time"] != ""  # Should have extracted time from "Meal (HH:MM)" format
```

**VALIDATE**:
```bash
cd 4_Pydantic_AI_Agent && pytest tests/test_meal_distribution.py -v
```

