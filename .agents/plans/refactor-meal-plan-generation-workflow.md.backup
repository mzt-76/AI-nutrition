    mock_openai.chat.completions.create.return_value.choices = [
        MagicMock(message=MagicMock(content=json.dumps(mock_valid_meal_plan())))
    ]

    mock_http = AsyncMock()

    # Call tool
    result_json = await generate_weekly_meal_plan_tool(
        supabase=mock_supabase,
        openai_client=mock_openai,
        http_client=mock_http,
        start_date="2024-12-23",
        meal_structure="3_consequent_meals"
    )

    result = json.loads(result_json)

    assert result["success"] == True
    assert "meal_plan_id" in result
    assert "markdown_document" in result

@pytest.mark.asyncio
async def test_workflow_fails_on_allergen_violation():
    """Test that workflow fails and logs error when allergen found."""
    # Mock profile with peanut allergy
    mock_supabase = MagicMock()
    mock_supabase.table.return_value.select.return_value.limit.return_value.execute.return_value.data = [
        {
            "age": 30,
            "gender": "male",
            "weight_kg": 80,
            "height_cm": 175,
            "allergies": ["arachides"],
            "target_calories": 3000,
            "target_protein_g": 180,
            "target_carbs_g": 375,
            "target_fat_g": 85
        }
    ]

    # Mock meal plan with peanut butter (violation)
    plan_with_allergen = {
        "meal_plan_id": "plan_2024-12-23",
        "start_date": "2024-12-23",
        "days": [{
            "day": "Lundi",
            "meals": [{
                "meal_type": "Petit-déjeuner",
                "recipe_name": "Tartine beurre cacahuète",
                "ingredients": [{"name": "peanut butter", "quantity": 30, "unit": "g"}],
                "nutrition": {"calories": 3000, "protein_g": 180, "carbs_g": 375, "fat_g": 85}
            }],
            "daily_totals": {"calories": 3000, "protein_g": 180, "carbs_g": 375, "fat_g": 85}
        }] * 7
    }

    mock_openai = AsyncMock()
    mock_openai.chat.completions.create.return_value.choices = [
        MagicMock(message=MagicMock(content=json.dumps(plan_with_allergen)))
    ]

    mock_http = AsyncMock()

    # Call tool
    result_json = await generate_weekly_meal_plan_tool(
        supabase=mock_supabase,
        openai_client=mock_openai,
        http_client=mock_http,
        start_date="2024-12-23",
        meal_structure="3_consequent_meals"
    )

    result = json.loads(result_json)

    assert "error" in result
    assert result["code"] == "VALIDATION_FAILED"
    assert "log_file" in result
    # Verify log file was created
    from pathlib import Path
    assert Path(result["log_file"]).exists()

