def test_validate_meal_plan_complete_all_levels_pass():
    """Test that complete validation passes when all criteria met."""
    plan = {
        "meal_plan_id": "plan_2024-12-23",
        "start_date": "2024-12-23",
        "days": [
            {
                "day": f"Jour {i+1}",
                "meals": [
                    {
                        "meal_type": "Petit-déjeuner",
                        "recipe_name": "Omelette",
                        "ingredients": [{"name": "eggs", "quantity": 3, "unit": "pieces"}],
                        "nutrition": {"calories": 500, "protein_g": 30, "carbs_g": 40, "fat_g": 15}
                    },
                    {
                        "meal_type": "Déjeuner",
                        "recipe_name": "Poulet riz",
                        "ingredients": [{"name": "chicken", "quantity": 200, "unit": "g"}],
                        "nutrition": {"calories": 1000, "protein_g": 60, "carbs_g": 100, "fat_g": 30}
                    },
                    {
                        "meal_type": "Dîner",
                        "recipe_name": "Saumon légumes",
                        "ingredients": [{"name": "salmon", "quantity": 150, "unit": "g"}],
                        "nutrition": {"calories": 1500, "protein_g": 90, "carbs_g": 135, "fat_g": 40}
                    }
                ],
                "daily_totals": {"calories": 3000, "protein_g": 180, "carbs_g": 275, "fat_g": 85}
            }
            for i in range(7)
        ]
    }

    target_macros = {"calories": 3000, "protein_g": 180, "carbs_g": 275, "fat_g": 85}
    result = validate_meal_plan_complete(plan, target_macros, [], "3_consequent_meals")

    assert result["valid"] == True
    assert result["validations"]["structure"]["valid"] == True
    assert result["validations"]["allergens"]["valid"] == True
    assert result["validations"]["macros"]["valid"] == True
    assert result["validations"]["completeness"]["valid"] == True

def test_validate_meal_plan_complete_fails_on_allergen():
    """Test that validation fails if allergen found."""
    plan = {
        "meal_plan_id": "plan_2024-12-23",
        "start_date": "2024-12-23",
        "days": [{
            "day": "Lundi",
            "meals": [{
                "meal_type": "Petit-déjeuner",
                "recipe_name": "Tartine beurre cacahuète",
                "ingredients": [{"name": "peanut butter", "quantity": 30, "unit": "g"}],
                "nutrition": {"calories": 500, "protein_g": 30, "carbs_g": 40, "fat_g": 15}
            }]
        }]
    }

    result = validate_meal_plan_complete(plan, {}, ["arachides"], "3_consequent_meals")

    assert result["valid"] == False
    assert result["validations"]["allergens"]["valid"] == False
    assert len(result["validations"]["allergens"]["violations"]) > 0

def test_validate_meal_plan_complete_fails_on_protein_deviation():
    """Test that validation fails if protein deviates > 5%."""
    plan = {
        "meal_plan_id": "plan_2024-12-23",
        "start_date": "2024-12-23",
        "days": [
            {
                "day": f"Jour {i+1}",
                "meals": [{
                    "meal_type": "Petit-déjeuner",
                    "recipe_name": "Low protein meal",
                    "ingredients": [{"name": "bread", "quantity": 100, "unit": "g"}],
                    "nutrition": {"calories": 3000, "protein_g": 100, "carbs_g": 400, "fat_g": 85}  # 100g protein vs 180g target = -44%
                }],
                "daily_totals": {"calories": 3000, "protein_g": 100, "carbs_g": 400, "fat_g": 85}
            }
            for i in range(7)
        ]
    }

    target_macros = {"calories": 3000, "protein_g": 180, "carbs_g": 375, "fat_g": 85}
    result = validate_meal_plan_complete(plan, target_macros, [], "3_consequent_meals", protein_tolerance=0.05)

    assert result["valid"] == False
    assert result["validations"]["macros"]["valid"] == False

def test_validate_meal_plan_complete_fails_on_incomplete_days():
    """Test that validation fails if less than 7 days."""
    plan = {
        "meal_plan_id": "plan_2024-12-23",
        "start_date": "2024-12-23",
        "days": [
            {
                "day": "Lundi",
                "meals": [{"meal_type": "Petit-déjeuner", "recipe_name": "Omelette", "ingredients": [], "nutrition": {}}]
            },
            {
                "day": "Mardi",
                "meals": [{"meal_type": "Petit-déjeuner", "recipe_name": "Pancakes", "ingredients": [], "nutrition": {}}]
            }
        ]  # Only 2 days instead of 7
    }

    result = validate_meal_plan_complete(plan, {}, [], "3_consequent_meals")

    assert result["valid"] == False
    assert result["validations"]["completeness"]["valid"] == False
```

