cd 4_Pydantic_AI_Agent && python -c "from nutrition.meal_planning import build_meal_plan_prompt_simple; profile = {'allergies': ['arachides'], 'target_calories': 3000, 'target_protein_g': 180, 'target_carbs_g': 375, 'target_fat_g': 85}; meal_dist = {'meals': [{'meal_type': 'Petit-déjeuner', 'time': '07:30', 'target_calories': 750, 'target_protein_g': 60, 'target_carbs_g': 90, 'target_fat_g': 25}]}; prompt = build_meal_plan_prompt_simple(profile, meal_dist, 'RAG', '2024-12-23'); assert len(prompt.split('\n')) < 150; assert 'arachides' in prompt; assert 'NE CALCULE PAS' in prompt.upper(); print(f'✅ Simplified prompt is {len(prompt.split(chr(10)))} lines')"
```

