def test_format_meal_plan_as_markdown_contains_headers():
    """Test that Markdown contains required headers."""
    plan = {
        "meal_plan_id": "plan_2024-12-23",
        "start_date": "2024-12-23",
        "days": [{
            "day": "Lundi 2024-12-23",
            "meals": [{
                "meal_type": "Petit-déjeuner",
                "time": "07:30",
                "recipe_name": "Omelette",
                "nutrition": {"calories": 500, "protein_g": 30, "carbs_g": 40, "fat_g": 15},
                "ingredients": [{"name": "eggs", "quantity": 3, "unit": "pieces"}],
                "instructions": "Cook eggs."
            }],
            "daily_totals": {"calories": 3000, "protein_g": 180, "carbs_g": 375, "fat_g": 85}
        }]
    }

    markdown = format_meal_plan_as_markdown(plan, 123)

    assert "# Plan Nutritionnel Hebdomadaire (ID: 123)" in markdown
    assert "## Lundi 2024-12-23" in markdown
    assert "### Petit-déjeuner - 07:30" in markdown

def test_format_meal_plan_as_markdown_contains_summary_table():
    """Test that Markdown contains summary table at end."""
    plan = {
        "meal_plan_id": "plan_2024-12-23",
        "start_date": "2024-12-23",
        "days": [
            {
                "day": "Lundi",
                "meals": [],
                "daily_totals": {"calories": 3000, "protein_g": 180, "carbs_g": 375, "fat_g": 85}
            }
        ]
