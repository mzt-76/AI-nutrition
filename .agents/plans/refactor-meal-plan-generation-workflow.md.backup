        "days": [{
            "day": "Lundi",
            "meals": [{
                "meal_type": "Déjeuner",
                "time": "12:30",
                "recipe_name": "Poulet riz",
                "nutrition": {"calories": 600, "protein_g": 50, "carbs_g": 60, "fat_g": 10},
                "ingredients": [
                    {"name": "chicken breast", "quantity": 200, "unit": "g"},
                    {"name": "white rice", "quantity": 150, "unit": "g"}
                ],
                "instructions": "Cook chicken. Cook rice. Serve."
            }]
        }],
        "meal_plan_id": "test",
        "start_date": "2024-12-23"
    }

    markdown = format_meal_plan_as_markdown(plan, 789)

    assert "- chicken breast: 200g" in markdown
    assert "- white rice: 150g" in markdown
