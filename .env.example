# =============================================================================
# AI Nutrition Assistant - Environment Variables
# Copy this file to .env and fill in your keys
# =============================================================================

# --- LLM (Main Agent) ---
# Supports OpenAI or Anthropic models
# Claude: set LLM_CHOICE=claude-haiku-4-5-20251001 and ANTHROPIC_API_KEY
# OpenAI: set LLM_CHOICE=gpt-4o-mini and LLM_API_KEY
LLM_CHOICE=claude-haiku-4-5-20251001
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=sk-ant-...

# --- LLM (Skill Scripts — used for recipe generation, custom recipes) ---
# Anthropic Claude Sonnet recommended for quality
# ANTHROPIC_API_KEY is shared with the main agent if using Claude

# --- Embeddings (RAG) ---
EMBEDDING_API_KEY=sk-...
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL_CHOICE=text-embedding-3-small

# --- Database ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# --- Web Search (optional) ---
BRAVE_API_KEY=BSA...
# OR use SearXNG (self-hosted, no API key needed)
SEARXNG_BASE_URL=

# --- Recipe Import Sources (optional) ---
SPOONACULAR_API_KEY=
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

# --- API / CORS ---
# Comma-separated origins allowed by CORS (NEVER use * in production)
CORS_ORIGINS=https://your-app.vercel.app

# --- Memory (optional, for cross-session context) ---
# mem0 uses OpenAI for its internal LLM + embeddings (even if your agent uses Claude).
# DATABASE_URL is required — it's the Postgres connection string from your Supabase project.
# Find it in Supabase → Settings → Database → Connection string (URI).
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
MEM0_LLM_CHOICE=gpt-4o-mini
