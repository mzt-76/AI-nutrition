VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_AGENT_ENDPOINT=http://localhost:8001/api/agent
VITE_ENABLE_STREAMING=true

# Set to "true" to enable file system polling in Vite (useful for WSL/Docker)
# VITE_USE_POLLING=true

# Production: set these to your deployed URLs, e.g.:
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_AGENT_ENDPOINT=https://api.your-domain.com/api/agent
